{
  "compilerOptions": {
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "strict": true,
    "types": ["node"],
    "lib": ["es2019", "es2020.promise", "es2020.bigint", "es2020.string"],
    "module": "commonjs",
    "target": "es2019"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/*"
  ]
}